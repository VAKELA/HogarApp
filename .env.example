# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL — direct connection for migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
# Database (Supabase PostgreSQL — pooler for runtime queries)
DATABASE_URL_POOLED=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres

# API
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Next.js
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001